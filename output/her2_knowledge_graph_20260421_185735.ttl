    her2:source_doc "ontology:seed" ;
    her2:supersededBy her2:Rakha_International_2026 .

her2:Group1 a her2:ISHGroup ;
    her2:confidence 1.0 ;
    her2:definition "ratio ≥2.0 AND signals ≥4.0/cell → Amplified (Positive)" ;
    her2:group_number 1 ;
    her2:implies her2:HER2_Positive ;
    her2:label "ISH Group 1" ;
    her2:ratio_threshold 2.0 ;
    her2:signals_per_cell_threshold 4.0 ;
    her2:source_doc "ontology:seed" ;
    owl:sameAs ncit:C173795 .

her2:Group2 a her2:ISHGroup ;
    her2:confidence 1.0 ;
    her2:definition "ratio ≥2.0 AND signals <4.0/cell → Requires IHC workup" ;
    her2:group_number 2 ;
    her2:label "ISH Group 2" ;
    her2:ratio_threshold 2.0 ;
    her2:requiresIHCWorkup her2:HER2_Equivocal ;
    her2:signals_per_cell_threshold 4.0 ;
    her2:source_doc "ontology:seed" ;
    owl:sameAs ncit:C173796 .

her2:Group3 a her2:ISHGroup ;
    her2:confidence 1.0 ;
    her2:definition "ratio <2.0 AND signals ≥6.0/cell → Requires IHC workup" ;
    her2:group_number 3 ;
    her2:label "ISH Group 3" ;
    her2:ratio_threshold 2.0 ;
    her2:requiresIHCWorkup her2:HER2_Equivocal ;
    her2:signals_per_cell_threshold 6.0 ;
    her2:source_doc "ontology:seed" ;
    owl:sameAs ncit:C173797 .

her2:Group4 a her2:ISHGroup ;
    her2:confidence 1.0 ;
    her2:definition "ratio <2.0 AND signals ≥4.0 and <6.0/cell → Requires IHC workup" ;
    her2:group_number 4 ;
    her2:label "ISH Group 4" ;
    her2:ratio_threshold 2.0 ;
    her2:requiresIHCWorkup her2:HER2_Equivocal ;
    her2:signals_per_cell_threshold 4.0 ;
    her2:source_doc "ontology:seed" ;
    owl:sameAs ncit:C173798 .

her2:Group5 a her2:ISHGroup ;
    her2:confidence 1.0 ;
    her2:definition "ratio <2.0 AND signals <4.0/cell → Not amplified (Negative)" ;
    her2:group_number 5 ;
    her2:implies her2:HER2_Low ;
    her2:label "ISH Group 5" ;
    her2:ratio_threshold 2.0 ;
    her2:signals_per_cell_threshold 4.0 ;
    her2:source_doc "ontology:seed" ;
    owl:sameAs ncit:C173799 .

her2:Lacunarity a her2:FractalMetric ;
    her2:confidence 1.0 ;
    her2:definition "Measure of spatial texture; low values = dense, high values = porous" ;
    her2:label "Lacunarity" ;
    her2:proposedCorrelation her2:Score3Plus ;
    her2:source_doc "ontology:seed" ;
    her2:value_range_high 1.0 ;
    her2:value_range_low 0.0 ;
    owl:sameAs ncit:C173800 .

her2:MultifractalSpread a her2:FractalMetric ;
    her2:confidence 1.0 ;
    her2:definition "Width of the multifractal spectrum; high values indicate high spatial variability" ;
