her2:10pct_Tumor_Cells a her2:Threshold ;
    her2:confidence 1.0 ;
    her2:definition "Threshold indicating that a second population of contiguous cells with increased HER2 signals/cell must consist of more than 10% of tumor cells." ;
    her2:evidence_level "" ;
    her2:label "10% Tumor Cells" ;
    her2:loinc_code "" ;
