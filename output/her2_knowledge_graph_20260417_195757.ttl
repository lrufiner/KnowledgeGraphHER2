her2:10pct_Threshold a her2:Threshold ;
    her2:confidence 1.0 ;
    her2:definition "More than 10% of tumor cells must show homogeneous, dark circumferential pattern to call result 3+, HER2 positive." ;
    her2:evidence_level "" ;
    her2:label "10% Threshold" ;
    her2:loinc_code "" ;
    her2:source_doc "her2_breast_update_sor_2023_c0004" ;
