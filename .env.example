# ── Copy this file to .env and fill in your actual values ──────────────────
# Never commit the real .env file (it is already in .gitignore)

# ── LLM provider ────────────────────────────────────────────────────────────
# Choices: ollama | claude | openai
HER2_KG_LLM_MODE=ollama

# Anthropic (required when HER2_KG_LLM_MODE=claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (required when HER2_KG_LLM_MODE=openai)
OPENAI_API_KEY=sk-...

# Ollama (used when HER2_KG_LLM_MODE=ollama)
OLLAMA_BASE_URL=http://localhost:11434
HER2_KG_OLLAMA_MODEL=qwen3:8b

# ── Embedding ────────────────────────────────────────────────────────────────
# Choices: ollama | openai
HER2_KG_EMBEDDING_MODE=ollama
HER2_KG_EMBEDDING_MODEL=nomic-embed-text

# ── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ── FastAPI / CORS ────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins
CORS_ALLOW_ORIGINS=http://localhost:8501,http://localhost:3000

# ── LangSmith observability (optional) ──────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=her2-kg

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Maximum requests per minute for /query endpoint
QUERY_RATE_LIMIT=10
